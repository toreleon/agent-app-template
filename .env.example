# OpenAI — works with api.openai.com OR an OpenAI-compatible endpoint
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: point at a custom/Azure endpoint (e.g. https://<resource>.services.ai.azure.com/openai/v1/)
OPENAI_BASE_URL=
# Optional: force a specific model / Azure deployment name (overrides the UI picker)
OPENAI_MODEL=

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# REQUIRED for the MCP Connectors OAuth flow: the redirect URI is derived as
# ${NEXTAUTH_URL}/api/mcp/oauth/callback, so this must be set and match the
# public origin (no trailing slash) for OAuth to complete.
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL="file:./dev.db"

# Sites — subdomain serving (Phase 0 of the "deployable mini-app" redesign;
# see docs/sites-mini-app-design.md)
# SITES_DOMAIN: the wildcard host published Sites are served from, as
# host[:port]. When set, each Site is served on its OWN origin at
# <slug>.<SITES_DOMAIN> (real per-site origin) and legacy /s/<slug> links 301 to
# it. When UNSET, Sites fall back to the legacy path-based, opaque-origin serving
# (nothing changes) — so this is safe to leave blank.
#   dev:  SITES_DOMAIN=localtest.me:3000   (*.localtest.me resolves to 127.0.0.1,
#         so no hosts-file/DNS setup is needed; it is a DIFFERENT registrable
#         domain than localhost, which is exactly the prod isolation posture)
#   prod: SITES_DOMAIN=mysites.app         (needs wildcard DNS + TLS for
#         *.mysites.app; use a DIFFERENT registrable domain than the app so the
#         app's auth cookie is unreachable from any site origin — the
#         Cloudflare-Pages / Vercel model)
SITES_DOMAIN=
# SITES_DATA_URL: the isolated SQLite database for the Sites mini-app data plane
# (Phase 1: per-site KV + document collections). SEPARATE from DATABASE_URL so
# anonymous public writes to a Site never serialize against the app's own DB
# (SQLite is single-writer per file). Defaults to a sibling of the app DB.
SITES_DATA_URL="file:./sites-data.db"

# Optional GitHub OAuth provider
GITHUB_ID=
GITHUB_SECRET=

# Scheduled tasks (Claude-Desktop-style automations)
# Two independent triggers funnel into the same runner; enable either or both.
# SCHEDULER_ENABLED: set to "1" to start the in-process 60s ticker (via Next.js
# instrumentation). Needs a long-lived Node server (next dev / next start); leave
# blank on serverless, where the process is not persistent.
SCHEDULER_ENABLED=
# CRON_SECRET: required to enable the POST/GET /api/cron endpoint (unset -> 503).
# External schedulers (crontab, Vercel Cron, GitHub Actions, …) send it as
# 'Authorization: Bearer <secret>' or 'X-Cron-Secret: <secret>'.
CRON_SECRET=

# Web tools (web_search / web_fetch)
# Both tools work with ZERO keys out of the box, but the keyless search path
# (DuckDuckGo HTML scraping) is fragile — set TAVILY_API_KEY or SEARXNG_URL for
# reliable results.
#
# WEB_SEARCH_PROVIDER: force a specific search backend
# (tavily | serper | brave | searxng | duckduckgo). Unset = auto-select by the
# precedence below (first backend whose credentials are present wins), falling
# back to the keyless DuckDuckGo scraper.
WEB_SEARCH_PROVIDER=
# Per-backend credentials — each one unset simply skips that backend during
# auto-selection. Precedence: tavily > serper > brave > searxng > duckduckgo.
# Tavily (recommended): https://tavily.com — LLM-oriented search API.
TAVILY_API_KEY=
# Serper: https://serper.dev — Google SERP API.
SERPER_API_KEY=
# Brave Search API: https://brave.com/search/api/
BRAVE_API_KEY=
# SearXNG: URL of a self-hosted, keyless SearXNG instance with the JSON format
# enabled (e.g. https://searx.example.com). Unset = skipped.
SEARXNG_URL=

# web_fetch: fetches a URL and returns cleaned Markdown, SSRF-guarded.
# WEBFETCH_EXTRACT_MODEL: unset = return the readability→markdown extraction as-is.
# Set to a (small/cheap) model name to run an isolated prompt-extraction pass over
# the page instead — opt-in, adds latency + token cost.
WEBFETCH_EXTRACT_MODEL=
# WEBFETCH_MAX_BYTES: hard cap on downloaded body size before extraction (default 5MB).
WEBFETCH_MAX_BYTES=
# WEBFETCH_TIMEOUT_MS: total fetch timeout across all redirect hops (default 15000).
WEBFETCH_TIMEOUT_MS=
# WEBFETCH_ALLOW_PRIVATE_NETWORK: unset/0 = block loopback/private/link-local
# addresses (SSRF protection, incl. cloud metadata). Set to 1 to allow them —
# LOCAL DEV ONLY; never enable in a deployment that fetches untrusted URLs.
WEBFETCH_ALLOW_PRIVATE_NETWORK=

# BROWSER_CONTROL_ENABLED: register the built-in browser-control tools
# (browser_navigate/snapshot/click/type/screenshot — a per-conversation headless
# Chromium driven by accessibility-tree refs). Unset/0 = off (default). Set to 1
# to enable. Requires `npx playwright install chromium`. Off by default until the
# connect-time SSRF guard-proxy + human-in-the-loop action confirmation ship.
BROWSER_CONTROL_ENABLED=
