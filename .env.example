# OpenAI — works with api.openai.com OR an OpenAI-compatible endpoint
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: point at a custom/Azure endpoint (e.g. https://<resource>.services.ai.azure.com/openai/v1/)
OPENAI_BASE_URL=
# Optional: force a specific model / Azure deployment name (overrides the UI picker)
OPENAI_MODEL=

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# REQUIRED for the MCP Connectors OAuth flow: the redirect URI is derived as
# ${NEXTAUTH_URL}/api/mcp/oauth/callback, so this must be set and match the
# public origin (no trailing slash) for OAuth to complete.
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL="file:./dev.db"

# Optional GitHub OAuth provider
GITHUB_ID=
GITHUB_SECRET=
