# OpenAI — works with api.openai.com OR an OpenAI-compatible endpoint
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: point at a custom/Azure endpoint (e.g. https://<resource>.services.ai.azure.com/openai/v1/)
OPENAI_BASE_URL=
# Optional: force a specific model / Azure deployment name (overrides the UI picker)
OPENAI_MODEL=

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# REQUIRED for the MCP Connectors OAuth flow: the redirect URI is derived as
# ${NEXTAUTH_URL}/api/mcp/oauth/callback, so this must be set and match the
# public origin (no trailing slash) for OAuth to complete.
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL="file:./dev.db"

# Optional GitHub OAuth provider
GITHUB_ID=
GITHUB_SECRET=

# Scheduled tasks (Claude-Desktop-style automations)
# Two independent triggers funnel into the same runner; enable either or both.
# SCHEDULER_ENABLED: set to "1" to start the in-process 60s ticker (via Next.js
# instrumentation). Needs a long-lived Node server (next dev / next start); leave
# blank on serverless, where the process is not persistent.
SCHEDULER_ENABLED=
# CRON_SECRET: required to enable the POST/GET /api/cron endpoint (unset -> 503).
# External schedulers (crontab, Vercel Cron, GitHub Actions, …) send it as
# 'Authorization: Bearer <secret>' or 'X-Cron-Secret: <secret>'.
CRON_SECRET=
