// Prisma schema for the ChatGPT clone.
// Provider: SQLite. DATABASE_URL="file:./dev.db"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String  @id @default(cuid())
  name           String?
  email          String  @unique
  hashedPassword String?
  image          String?
  // JSON-encoded global custom instructions (ChatGPT "Customize ChatGPT"):
  // { nickname, occupation, traits, about, enabled }. Injected into the system
  // prompt for every chat when enabled — see src/lib/user/prompt.ts.
  customInstructions String?
  createdAt      DateTime @default(now())

  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  mcpServers    McpServer[]
  schedules     Schedule[]
  projects      Project[]
  plugins       Plugin[]
}

// ---- NextAuth standard models ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Application models ----

model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("New chat")
  userId    String
  model     String
  // Set when this conversation was created by a scheduled-task run. Nulled (not
  // cascaded) if the owning Schedule is deleted, so past run chats survive.
  scheduleId String?
  // Set when this conversation belongs to a Project (ChatGPT/Claude-style). The
  // project's custom instructions + knowledge files are injected into the system
  // prompt for every turn in this chat. Deleting a project deletes its chats,
  // handled in application code (see DELETE /api/projects/[id]); "Remove from
  // project" nulls this column instead.
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule  Schedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages  Message[]
  artifacts Artifact[]

  @@index([userId])
  @@index([scheduleId])
  @@index([projectId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant" | "system" | "tool"
  content        String // Text
  attachments    String? // JSON-encoded Attachment[]
  toolCalls      String? // JSON-encoded tool call/result records
  reasoning      String? // Reasoning summary text (assistant messages only)
  reasoningMs    Int? // Total thinking wall-clock (reasoning + tools), in ms
  timeline       String? // JSON-encoded TraceItem[] — ordered interleaved reasoning + tool activity
  artifactRefs   String? // JSON-encoded ArtifactRef[] — artifacts this message created/updated
  research       String? // JSON-encoded ResearchState — Deep Research plan + activity log
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// A Claude-Desktop-style Artifact: a substantial, self-contained, versioned
// piece of content (code, document, HTML/SVG, Mermaid diagram, or interactive
// React component) produced by the assistant via the artifact tools and rendered
// in a side panel. Each Artifact belongs to one conversation and is targeted by
// the model via a stable, conversation-unique `identifier`. Every edit appends a
// new ArtifactVersion so the user can step through history.
model Artifact {
  id             String   @id @default(cuid())
  conversationId String
  // Model-provided stable slug, unique within the conversation. update/rewrite
  // target an existing artifact by this identifier.
  identifier     String
  // ArtifactType: "code" | "markdown" | "html" | "svg" | "mermaid" | "react"
  type           String
  title          String
  // Language hint for "code" artifacts (e.g. "python"); null for other types.
  language       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  versions     ArtifactVersion[]

  @@unique([conversationId, identifier])
  @@index([conversationId])
}

// One immutable snapshot of an Artifact's content. `version` is 1-based and
// increments on every create/update/rewrite. `messageId` links the version back
// to the assistant message that produced it (used to render inline chips).
model ArtifactVersion {
  id         String   @id @default(cuid())
  artifactId String
  version    Int
  content    String // Full content snapshot at this version
  messageId  String? // Assistant message that produced this version
  createdAt  DateTime @default(now())

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, version])
  @@index([artifactId])
}

// A remote MCP (Model Context Protocol) server registered by a user, exposed in
// the UI as a "Connector" (ChatGPT-style). Its tools are surfaced to the chat
// agent when the connector is enabled + trusted + connected. All OAuth secrets
// and tokens live ONLY in these columns and are never serialized to the client
// (the API returns a sanitized McpConnector DTO — see src/lib/types.ts).
model McpServer {
  id          String  @id @default(cuid())
  userId      String
  name        String
  url         String // MCP endpoint URL (Streamable HTTP)
  description String?
  enabled     Boolean @default(true)
  trusted     Boolean @default(false)
  // "none" | "pending" | "connected" | "error"
  authStatus  String  @default("pending")

  // ---- OAuth 2.1 (server-side only) ----
  oauthClientId     String?
  oauthClientSecret String?
  // JSON: { authorizationEndpoint, tokenEndpoint, registrationEndpoint?, resource?, scope? }
  oauthMetadata     String?
  accessToken       String?
  refreshToken      String?
  tokenExpiresAt    DateTime?
  pkceVerifier      String? // transient, set during a pending authorization
  oauthState        String? // CSRF state, maps the OAuth callback back to this row

  toolsCache String? // JSON-encoded McpToolInfo[]
  lastError  String?

  // Set when this server was registered from a plugin's bundled MCP config
  // (.mcp.json). Plain column, NOT a Prisma relation — uninstalling a plugin
  // deletes its bundled servers via an explicit deleteMany in application code
  // (SQLite FK enforcement is off; cascades are emulated). Null for servers the
  // user added by hand in the Connectors UI.
  pluginId String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pluginId])
}

// A user-installed Claude plugin (skills + optional bundled MCP servers). Cloned
// from a git repo or copied from a local folder into `installPath` (under
// .plugins/<userId>/<id>, outside the model-visible sandbox). Its SKILL.md
// skills are exposed to the agent via progressive disclosure: only each skill's
// name+description sits in the system prompt (see src/lib/plugins/context.ts),
// and the model pulls a skill's full body on demand through the `skill` tool.
// `skillsCache` holds the discovered skills as JSON (mirrors McpServer.toolsCache)
// so per-skill enable/disable is a JSON mutation with no second table. Only
// enabled plugins' enabled skills are injected. Deleting a plugin cascades (in
// app code) to its bundled McpServer rows and removes `installPath` from disk.
model Plugin {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  version     String?
  author      String?
  // "git" | "local"
  sourceType  String
  sourceUrl   String // git URL or local path as the user entered it
  gitRef      String? // branch/tag/commit for a git source
  marketplace String? // marketplace name when installed from a marketplace repo
  installPath String // absolute path of the cloned/copied plugin tree on disk
  skillsCache String? // JSON-encoded PluginSkill[] ({ name, description, dir, enabled })
  enabled     Boolean @default(true)
  lastError   String? // install/parse warnings (e.g. skipped stdio MCP servers)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A user-defined scheduled task (Claude-Desktop-style automation). At each fire
// the scheduler seeds a NEW conversation with `prompt` and runs the agent as the
// owning user; every attempt is logged as a ScheduleRun. `cron` (5-field) is the
// source of truth, evaluated in `timezone` (IANA). `nextRunAt`/`lastRunAt` are in
// UTC. `nextRunAt` doubles as the atomic claim token (compare-and-swap) so the
// in-process ticker and the external /api/cron endpoint never double-fire a run.
model Schedule {
  id        String  @id @default(cuid())
  userId    String
  title     String
  prompt    String // the task instruction, sent as the seed user message
  model     String
  effort    String  @default("medium") // ReasoningEffort
  cron      String // 5-field cron expression (minute hour dom month dow)
  timezone  String  @default("UTC") // IANA tz the cron is evaluated in
  enabled   Boolean @default(true)

  nextRunAt DateTime? // next fire time (UTC); also the CAS claim token
  lastRunAt DateTime? // last time a run was claimed (UTC)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs          ScheduleRun[]
  conversations Conversation[]

  @@index([userId])
  @@index([enabled, nextRunAt])
}

// One fire attempt of a Schedule. Run health is derived from this log, NOT from
// Schedule.lastRunAt (which is claim-time and rolled forward before the agent
// runs). `conversationId` links to the chat the run produced.
model ScheduleRun {
  id             String    @id @default(cuid())
  scheduleId     String
  status         String    @default("running") // "running" | "success" | "error"
  trigger        String    @default("cron") // "cron" | "manual"
  conversationId String? // conversation created for this run
  error          String? // failure message when status = "error"
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}

// A ChatGPT/Claude-style Project: a workspace that groups conversations around a
// shared purpose. Its `instructions` (custom instructions) and attached
// knowledge `files` are composed into the system prompt for every chat in the
// project (see src/lib/projects/prompt.ts). Deleting a project cascades to its
// files (real FK below) and — handled in application code — to its chats.
model Project {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String? // optional short summary shown on the project card
  instructions String? // custom instructions injected into every chat's system prompt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  files         ProjectFile[]
  conversations Conversation[]

  @@index([userId])
}

// One knowledge file attached to a Project. The raw file is persisted under
// public/uploads (like message attachments); `content` holds the extracted
// UTF-8 text used as reference context, or null when the type is unsupported or
// extraction failed (the file is still listed, just not fed to the model).
model ProjectFile {
  id        String   @id @default(cuid())
  projectId String
  name      String // original filename
  type      String // MIME type
  size      Int // bytes
  url       String // "/uploads/<stored>"
  content   String? // extracted text (knowledge); null when unavailable
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
